# Copy this file to `.env.local` and fill in your Supabase project values.
# Both values are SAFE to ship to the browser — Row-Level Security in Postgres
# is what actually protects user data, not key secrecy. Never put a service-role
# key here.
#
# Where to find them: https://app.supabase.com → your project → Settings → API.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Leave both blank to run the app fully offline (localStorage only, no sync).
